# Copy to `.env` and fill in. Never commit `.env`.
# Used by scripts/build_investor_pitch_pdf.py --email

ALGOSPHERE_SMTP_USER=
ALGOSPHERE_SMTP_PASSWORD=
ALGOSPHERE_SMTP_HOST=smtp.gmail.com
ALGOSPHERE_SMTP_PORT=465
ALGOSPHERE_SMTP_FROM=

# Private Streamlit views: Investor (private) / Partner (private)
# If unset, built-in demo passwords apply (see Streamlit login screen).
ALGOSPHERE_PRIVATE_INVESTOR_PASSWORD=
ALGOSPHERE_PRIVATE_PARTNER_PASSWORD=

# Public deploy (e.g. Render): restrict sidebar to allocator-only pages (no Admin / Client).
# ALGOSPHERE_PUBLIC_SURFACE=investor
# Full base URL of FastAPI when dashboard runs in the cloud (no trailing slash).
# ALGO_SPHERE_API_URL=https://your-api.onrender.com
